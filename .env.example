# ── Database ──────────────────────────────────────────────────────────────────
# For Docker: automatically set in docker-compose.yml — no change needed
# For local:  use SQLite (no install required) or your own Postgres URL
DATABASE_URL=sqlite:///./karivari.db

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Stripe (optional — card payments) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=usd
STRIPE_WEBHOOK_SECRET=

# ── Flutterwave (optional — MTN/Airtel MoMo) ─────────────────────────────────
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
PAYMENT_REDIRECT_URL=http://localhost:8000/payments/callback

# ── Paystack (optional) ───────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── Email / SMTP (optional — leave blank to skip sending) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@karivari.ug
SMTP_FROM_NAME=Kari Vari Uganda
SMTP_USE_TLS=true
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
